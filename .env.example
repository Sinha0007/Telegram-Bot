# -----------------------------------------------
# Telegram Bot
# -----------------------------------------------
BOT_TOKEN=your_bot_token_from_botfather
ALERT_CHANNEL_ID=your_telegram_channel_id

# -----------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/sniffalpha

# -----------------------------------------------
# Social Monitoring
# -----------------------------------------------
TWITTER_BEARER_TOKEN=your_twitter_v2_bearer_token
TELEGRAM_API_ID=your_telegram_app_id
TELEGRAM_API_HASH=your_telegram_app_hash
TELEGRAM_SESSION=your_gramjs_session_string

# -----------------------------------------------
# Blockchain - Solana
# -----------------------------------------------
HELIUS_API_KEY=your_helius_api_key
# BIRDEYE_API_KEY=optional_if_you_want_richer_mc_data

# -----------------------------------------------
# Alert Dispatcher
# -----------------------------------------------
# REDIS_URL=redis://localhost:6379          # optional — falls back to in-memory
ALERT_COOLDOWN_MINUTES=120                  # default 2 hours per ticker
ALERT_SCORE_THRESHOLD=10                    # min alpha score delta to re-alert

# -----------------------------------------------
# Express API Server
# -----------------------------------------------
PORT=3000

# -----------------------------------------------
# Webhooks (optional)
# -----------------------------------------------
DEFAULT_WEBHOOK_URL=https://your-server.com/hook
